#!/usr/bin/env bash
# Add a permission to Claude settings
#
# Usage:
#   bless-cmd npm run dev            # → Bash(npm run dev:*) in project settings
#   bless-cmd -g npm run dev         # → same, in global ~/.claude/settings.json
#   bless-cmd -r WebFetch            # Raw: adds exactly as given (no Bash wrapper)

set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || $# -eq 0 ]]; then
  echo "Usage: bless-cmd [-g] [-r] <command...>"
  echo "  bless-cmd npm run dev        # → Bash(npm run dev:*) (project)"
  echo "  bless-cmd -g npm run dev     # → same (global)"
  echo "  bless-cmd -r 'WebFetch'      # Raw: adds exactly as given"
  exit 0
fi

raw=false
global=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -r) raw=true; shift ;;
    -g) global=true; shift ;;
    *) break ;;
  esac
done

cmd="$*"
if [[ -z "$cmd" ]]; then
  echo "Error: no command specified" >&2
  exit 1
fi

if $global; then
  settings="$HOME/.claude/settings.json"
else
  settings=".claude/settings.local.json"
fi

# Format permission string
if $raw; then
  perm="$cmd"
else
  perm="Bash($cmd:*)"
fi

# Create settings file if needed
if [[ ! -f "$settings" ]]; then
  mkdir -p "$(dirname "$settings")"
  echo '{}' > "$settings"
fi

# Check if already present
if jq -e ".permissions.allow // [] | index(\"$perm\")" "$settings" >/dev/null 2>&1; then
  echo "Already permitted: $perm"
  exit 0
fi

# Add permission
jq --arg perm "$perm" '
  .permissions.allow = ((.permissions.allow // []) + [$perm])
' "$settings" > "$settings.tmp" && mv "$settings.tmp" "$settings"

label="global"
$global || label="project"
echo "Added ($label): $perm"
echo "Restart Claude to apply: claude -c"
