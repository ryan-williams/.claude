#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
r"""Auto-approve (or deny) Bash commands based on rules in YAML specs.

Reads rules from:
  1. $CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve.yml (project, checked first)
  2. ~/.claude/hooks/auto-approve.yml (global, fallback)

First match wins across both files. No match = normal permission prompt.

Pipelines and compound commands (|, &&, ||, ;, \n) are split into
segments; ALL segments must be approved for the whole command to pass.

Rule types:
  allow: / deny: / ask:                    Shlex-aware token matching (recommended)
  allow-regex: / deny-regex: / ask-regex:  Raw regex on command string (fallback)

Actions:
  allow   auto-approve, skip permission prompt
  ask     stop matching, show normal permission prompt (user decides)
  deny    hard block, never run

Rule value formats:
  String    Single pattern: 'allow: git log'
  List      Each item is a standalone pattern:
              allow:
                - cat
                - head
                - tail
  Dict      Trie: keys are prefix patterns, values are lists of
            allowed next tokens (or nested dicts for deeper nesting):
              allow:
                git: [branch, diff, log, status]
                git -C *: [branch, diff, log, status]
                pnpm: [add, build, test]

Token pattern syntax (within strings):
  Bare word     Literal match against one shlex token
  *             Any single token
  (a|b|c)       Alternation of literals
  "text *"      One token matching glob (shlex-parsed, * = .*)
  $             End anchor: no extra trailing args allowed

Prefix matching by default: extra args after the pattern are OK.

Safety / FP analysis
--------------------
The architecture is designed so that false positives (auto-approving
something unsafe) require MULTIPLE failures to align:

1. Pipeline splitting runs FIRST on the raw command string, splitting on
   unquoted |, &&, ||, ;, &, \n. Each resulting segment is evaluated
   independently. ALL must be 'allow' for the command to pass.

2. Each segment is matched against rules using shlex-parsed tokens (not
   raw string matching). Prefix matching means "the command starts with
   these tokens" — extra trailing args are OK but cannot change the base
   command identity.

FP can only occur if:
  - The pipeline splitter FAILS to split on a real command separator,
    causing two commands to be evaluated as one. The first command
    matches a rule, so the combined string is approved, but the second
    command (which wouldn't match) also executes.
  - This requires a separator char that bash interprets but our splitter
    doesn't recognize. Known gaps:
      * ANSI-C quoting: $'\x3b' (literal ;) — not split
      * Process substitution: <(cmd), >(cmd) — not parsed
      * Brace groups: { cmd1; cmd2; } — inner ; not split
      * Subshells: (cmd1; cmd2) — inner ; not split
    These are rare in Claude-generated commands.
  - OR a rule pattern is overly broad. Each rule should include enough
    specificity (flags, subcommands) to constrain the match. E.g., a
    rule 'allow: rm' would approve 'rm -rf /' — always include the
    flags: 'allow: rm -rf (node_modules|dist|...)'.

Known limitations (cause false negatives → manual prompt, NOT FPs):
  - shlex.split() doesn't understand $() — commands with command
    substitution need allow-regex: instead of allow:
  - Heredocs (<<EOF) not handled — treated as regular text
  - Complex nested compounds may not reassemble correctly
  - Line continuations (\<newline>) are handled, but other obscure
    bash quoting ($'...' ANSI-C strings) is not
"""

from datetime import datetime
from pathlib import Path
import json
import os
import re
import shlex
import sys
import yaml

LOG_FILE = Path.home() / ".claude" / "hooks" / "auto-approve.log"


# ── Token matchers ───────────────────────────────────────────────

class Literal:
    __slots__ = ("text",)
    def __init__(self, text):
        self.text = text
    def matches(self, token):
        return token == self.text

class AnyToken:
    def matches(self, _token):
        return True

class Alternation:
    __slots__ = ("options",)
    def __init__(self, options):
        self.options = frozenset(options)
    def matches(self, token):
        return token in self.options

class GlobPattern:
    """Matches one token against a glob pattern (* = .*)."""
    __slots__ = ("regex",)
    def __init__(self, pattern):
        escaped = re.escape(pattern).replace(r"\*", ".*")
        self.regex = re.compile(f"^{escaped}$")
    def matches(self, token):
        return bool(self.regex.match(token))


# Sentinel for end-of-pattern anchor
END_ANCHOR = object()


def parse_pattern(pattern_str: str) -> list:
    """Parse a pattern string into a list of token matchers."""
    matchers = []
    i = 0
    n = len(pattern_str)

    while i < n:
        # Skip whitespace
        while i < n and pattern_str[i] == " ":
            i += 1
        if i >= n:
            break

        c = pattern_str[i]

        # End anchor
        if c == "$" and i == n - 1:
            matchers.append(END_ANCHOR)
            i += 1

        # Alternation: (a|b|c)
        elif c == "(":
            j = pattern_str.find(")", i + 1)
            if j == -1:
                # Malformed, treat rest as literal
                matchers.append(Literal(pattern_str[i:]))
                break
            options = pattern_str[i + 1 : j].split("|")
            matchers.append(Alternation(options))
            i = j + 1

        # Quoted string (may contain wildcards)
        elif c in ('"', "'"):
            quote = c
            j = i + 1
            while j < n and pattern_str[j] != quote:
                if pattern_str[j] == "\\" and j + 1 < n:
                    j += 2
                else:
                    j += 1
            inner = pattern_str[i + 1 : j]
            if "*" in inner:
                matchers.append(GlobPattern(inner))
            else:
                matchers.append(Literal(inner))
            i = j + 1

        # Bare token
        else:
            j = i
            while j < n and pattern_str[j] != " ":
                j += 1
            token = pattern_str[i:j]
            if token == "*":
                matchers.append(AnyToken())
            elif "*" in token:
                matchers.append(GlobPattern(token))
            else:
                matchers.append(Literal(token))
            i = j

    return matchers


def match_tokens(matchers: list, tokens: list[str]) -> bool:
    """Match parsed matchers against shlex-parsed tokens.

    Prefix matching by default. END_ANCHOR requires exact length.
    """
    exact = matchers and matchers[-1] is END_ANCHOR
    if exact:
        matchers = matchers[:-1]

    if len(tokens) < len(matchers):
        return False
    if exact and len(tokens) != len(matchers):
        return False

    for matcher, token in zip(matchers, tokens):
        if not matcher.matches(token):
            return False
    return True


def shlex_split_safe(command: str) -> list[str] | None:
    """shlex.split with fallback for malformed input."""
    try:
        return shlex.split(command)
    except ValueError:
        return None


# ── Shell pipeline splitting ─────────────────────────────────────

def _reassemble_compounds(segments: list[str]) -> list[str]:
    """Reassemble shell compound commands split across segments.

    Handles for/do/done, while/do/done, until/do/done, if/then/fi,
    case/in/esac. These get split by `;` but should be treated as
    single compound commands.
    """
    # Openers and their closers
    OPENERS = {"for", "while", "until", "if", "case"}
    CLOSERS = {"done": {"for", "while", "until"}, "fi": {"if"}, "esac": {"case"}}

    result = []
    compound_parts: list[str] = []
    depth = 0
    opener_stack: list[str] = []

    for seg in segments:
        # Get the first word to check for openers/closers
        first_word = seg.split()[0] if seg.split() else ""
        # Also check "do cmd" → first word is "do"
        # Strip leading "do " to get to potential nested opener
        base_word = first_word

        if depth == 0 and base_word in OPENERS:
            depth += 1
            opener_stack.append(base_word)
            compound_parts.append(seg)
        elif depth > 0:
            compound_parts.append(seg)
            # Check for nested openers
            if base_word in OPENERS:
                depth += 1
                opener_stack.append(base_word)
            # Check for closers
            # "done" can appear as the whole segment or start of it
            last_word = seg.rstrip().split()[-1] if seg.split() else ""
            if last_word in CLOSERS:
                matching = CLOSERS[last_word]
                if opener_stack and opener_stack[-1] in matching:
                    depth -= 1
                    opener_stack.pop()
            if depth == 0:
                # Reassemble with "; " separator
                result.append("; ".join(compound_parts))
                compound_parts = []
        else:
            result.append(seg)

    # If we have unclosed compounds, emit them anyway
    if compound_parts:
        result.append("; ".join(compound_parts))

    return result


def split_shell_commands(command: str) -> list[str]:
    """Split a shell command on unquoted |, &&, ||, ;, & operators.

    Respects single quotes, double quotes, $() / `` substitutions,
    backslash escapes, and shell compound commands (for/done, if/fi, etc.).
    """
    segments = []
    current: list[str] = []
    i = 0
    n = len(command)

    while i < n:
        c = command[i]

        if c == "'":
            j = command.find("'", i + 1)
            if j == -1:
                current.append(command[i:])
                i = n
            else:
                current.append(command[i : j + 1])
                i = j + 1
        elif c == '"':
            j = i + 1
            while j < n:
                if command[j] == "\\" and j + 1 < n:
                    j += 2
                elif command[j] == '"':
                    break
                else:
                    j += 1
            current.append(command[i : j + 1])
            i = j + 1
        elif c == "$" and i + 1 < n and command[i + 1] == "(":
            depth = 1
            j = i + 2
            while j < n and depth > 0:
                if command[j] == "\\" and j + 1 < n:
                    j += 2
                    continue
                if command[j] == "(":
                    depth += 1
                elif command[j] == ")":
                    depth -= 1
                j += 1
            current.append(command[i:j])
            i = j
        elif c == "`":
            j = command.find("`", i + 1)
            if j == -1:
                current.append(command[i:])
                i = n
            else:
                current.append(command[i : j + 1])
                i = j + 1
        elif c == "\\" and i + 1 < n:
            if command[i + 1] == "\n":
                # Line continuation: skip both \ and \n
                i += 2
            else:
                current.append(command[i : i + 2])
                i += 2
        elif c == "|" and i + 1 < n and command[i + 1] == "|":
            seg = "".join(current).strip()
            if seg:
                segments.append(seg)
            current = []
            i += 2
        elif c == "|":
            seg = "".join(current).strip()
            if seg:
                segments.append(seg)
            current = []
            i += 1
        elif c == "&" and i + 1 < n and command[i + 1] == "&":
            seg = "".join(current).strip()
            if seg:
                segments.append(seg)
            current = []
            i += 2
        elif c == "&":
            # Check for redirect: N>& or >& (not a pipeline operator)
            cur_str = "".join(current)
            if cur_str and cur_str[-1] == ">" or (len(cur_str) >= 2 and cur_str[-2].isdigit() and cur_str[-1] == ">"):
                current.append(c)
                i += 1
            else:
                # Background operator: split here
                seg = cur_str.strip()
                if seg:
                    segments.append(seg)
                current = []
                i += 1
        elif c in (";", "\n"):
            seg = "".join(current).strip()
            if seg:
                segments.append(seg)
            current = []
            i += 1
        else:
            current.append(c)
            i += 1

    seg = "".join(current).strip()
    if seg:
        segments.append(seg)
    return _reassemble_compounds(segments)


# ── Rule loading and matching ────────────────────────────────────

def load_rules(path: Path) -> list[dict]:
    """Load rules from a YAML spec file."""
    if not path.is_file():
        return []
    try:
        data = yaml.safe_load(path.read_text())
        return data.get("rules", []) if isinstance(data, dict) else []
    except Exception as e:
        print(f"Warning: failed to parse {path}: {e}", file=sys.stderr)
        return []


def _unwrap_assignment(command: str) -> str:
    """Unwrap variable assignments to get the actual command.

    'VAR=$(cmd args)' → 'cmd args'
    'export VAR=$(cmd)' → 'cmd'
    'local VAR=value' → '' (no command)
    'VAR=value cmd args' → 'cmd args' (env prefix)
    'cmd args' → 'cmd args' (unchanged)
    """
    cmd = command
    # Strip export/local/declare/readonly prefix
    m = re.match(r'^(export|local|declare|readonly|typeset)\s+', cmd)
    if m:
        cmd = cmd[m.end():]
    # Match VAR=...$(...) or VAR=$(...) patterns
    m = re.match(r'^[A-Za-z_]\w*=\$\((.+)\)\s*$', cmd)
    if m:
        return m.group(1)
    # Plain assignment: VAR=value (no command to evaluate)
    if re.match(r'^[A-Za-z_]\w*=\S*\s*$', cmd):
        return ""
    # Env-prefix pattern: VAR=value cmd args → evaluate 'cmd args'
    m = re.match(r'^[A-Za-z_]\w*=\S*\s+(.+)$', cmd)
    if m:
        return m.group(1)
    return cmd


def _match_trie(tokens: list[str], trie: dict) -> bool:
    """Match tokens against a trie (dict) structure.

    Keys are pattern prefixes (parsed with parse_pattern).
    Values can be:
      - list of strings: allowed next tokens (any matches → allow)
      - dict: recurse deeper
      - null/true: match here (prefix match, trailing args OK)
    """
    for prefix_str, subtree in trie.items():
        prefix_matchers = parse_pattern(prefix_str)
        if len(tokens) < len(prefix_matchers):
            continue
        # Check prefix matches
        if not all(m.matches(t) for m, t in zip(prefix_matchers, tokens)):
            continue
        remaining = tokens[len(prefix_matchers):]

        if subtree is None or subtree is True:
            return True
        elif isinstance(subtree, list):
            # List of allowed next tokens
            if not remaining:
                return True  # No next token needed
            alternation = Alternation(subtree)
            if alternation.matches(remaining[0]):
                return True
        elif isinstance(subtree, dict):
            if _match_trie(remaining, subtree):
                return True
    return False


def match_rules(command: str, rules: list[dict]) -> str | None:
    """Evaluate rules against a single command segment.

    Returns 'allow', 'deny', 'ask', or None.
      allow → auto-approve
      deny  → hard block
      ask   → stop matching, fall through to normal permission prompt
      None  → no rule matched, continue to normal prompt

    Pattern value types:
      str  → single pattern (parsed with parse_pattern)
      list → each item is a standalone pattern string
      dict → trie: keys are prefixes, values are lists/dicts/null
    """
    # Unwrap variable assignments
    command = _unwrap_assignment(command)
    if not command:
        return "allow"  # Plain assignment, always safe

    tokens = shlex_split_safe(command)

    for rule in rules:
        if not isinstance(rule, dict):
            continue

        for action_key in ("allow", "deny", "ask", "allow-regex", "deny-regex", "ask-regex"):
            pattern = rule.get(action_key)
            if pattern is None:
                continue

            action = action_key.split("-")[0]  # "allow" or "deny"

            if action_key.endswith("-regex"):
                # Raw regex match on command string
                try:
                    if re.search(pattern, command):
                        return action
                except re.error as e:
                    print(f"Warning: bad regex {pattern!r}: {e}", file=sys.stderr)
            elif isinstance(pattern, list):
                # List of patterns: each is a standalone pattern string
                if tokens is None:
                    continue
                for pat in pattern:
                    try:
                        matchers = parse_pattern(str(pat))
                        if match_tokens(matchers, tokens):
                            return action
                    except Exception as e:
                        print(f"Warning: bad pattern {pat!r}: {e}", file=sys.stderr)
            elif isinstance(pattern, dict):
                # Trie: keys are prefixes, values are subtrees
                if tokens is None:
                    continue
                try:
                    if _match_trie(tokens, pattern):
                        return action
                except Exception as e:
                    print(f"Warning: bad trie pattern: {e}", file=sys.stderr)
            else:
                # String: single pattern
                if tokens is None:
                    continue
                try:
                    matchers = parse_pattern(str(pattern))
                    if match_tokens(matchers, tokens):
                        return action
                except Exception as e:
                    print(f"Warning: bad pattern {pattern!r}: {e}", file=sys.stderr)

    return None


def _extract_compound_body(segment: str) -> list[str] | None:
    """Extract body commands from a compound statement.

    For 'for ...; do cmd1; cmd2; done' → ['cmd1', 'cmd2']
    For 'if ...; then cmd; fi' → ['cmd']
    Returns None if not a compound statement.
    """
    first_word = segment.split()[0] if segment.split() else ""
    if first_word not in ("for", "while", "until", "if", "case"):
        return None

    # Split on "; " (the separator used by _reassemble_compounds)
    parts = [p.strip() for p in segment.split(";") if p.strip()]

    body = []
    BODY_STARTERS = ("do", "then", "else")
    CLOSERS = ("done", "fi", "esac")
    in_body = False

    for part in parts:
        words = part.split()
        if not words:
            continue
        fw = words[0]
        lw = words[-1]

        if fw in BODY_STARTERS:
            rest = part[len(fw):].strip()
            if rest and rest not in CLOSERS:
                body.append(rest)
            in_body = True
        elif fw in CLOSERS or lw in CLOSERS:
            # "done" alone or "cmd done" — skip
            in_body = False
        elif in_body:
            body.append(part)

    return body if body else None


def evaluate_command(command: str, rules: list[dict]) -> str | None:
    """Evaluate a full command, splitting pipelines/compounds.

    ALL segments must be 'allow' → allow.
    ANY segment 'deny' → deny.
    ANY segment 'ask' or None → None (normal prompt).

    Compound commands (for/done, if/fi, etc.) are decomposed: their
    body commands are evaluated individually.
    """
    segments = split_shell_commands(command)
    # Filter out comments and empty segments
    segments = [s for s in segments if s and not s.lstrip().startswith("#")]
    if not segments:
        return None

    if len(segments) == 1:
        # Check if it's a compound command
        body = _extract_compound_body(segments[0])
        if body:
            segments = body
        else:
            decision = match_rules(segments[0], rules)
            # 'ask' → fall through to normal prompt (same as None)
            return None if decision == "ask" else decision

    # Expand any compound segments into their body commands
    expanded = []
    for seg in segments:
        body = _extract_compound_body(seg)
        if body:
            expanded.extend(body)
        else:
            expanded.append(seg)

    has_ask = False
    for seg in expanded:
        decision = match_rules(seg, rules)
        if decision == "deny":
            return "deny"
        if decision in (None, "ask"):
            has_ask = True

    return None if has_ask else "allow"


# ── Main ─────────────────────────────────────────────────────────

def main():
    hook_input = json.load(sys.stdin)
    command = hook_input.get("tool_input", {}).get("command", "")
    if not command:
        return

    all_rules = []
    project_dir = os.environ.get("CLAUDE_PROJECT_DIR", "")
    if project_dir:
        all_rules.extend(
            load_rules(Path(project_dir) / ".claude" / "hooks" / "auto-approve.yml")
        )
    all_rules.extend(load_rules(Path.home() / ".claude" / "hooks" / "auto-approve.yml"))

    decision = evaluate_command(command, all_rules)

    # Log
    try:
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        home = str(Path.home())
        proj = project_dir.replace(home, "~") if project_dir else "-"
        label = decision or "ask"
        cmd_short = command[:120]
        with open(LOG_FILE, "a") as f:
            f.write(f"{ts}  {label:5s}  {proj}  {cmd_short}\n")
    except Exception:
        pass

    if decision is None:
        return

    result = {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": decision,
        }
    }
    if decision == "deny":
        result["hookSpecificOutput"]["permissionDecisionReason"] = (
            "Denied by auto-approve hook"
        )
    json.dump(result, sys.stdout)


if __name__ == "__main__":
    main()
