#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
r"""Auto-approve (or deny) Bash commands based on rules in YAML specs.

Reads rules from:
  1. $CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve.yml (project, checked first)
  2. ~/.claude/hooks/auto-approve.yml (global, fallback)

First match wins across both files. No match = normal permission prompt.
See hooks/auto_approve.py for the engine and full safety analysis.
"""

from datetime import datetime
from pathlib import Path
import json
import os
import sys

# Add hooks dir to path so we can import the engine
sys.path.insert(0, str(Path(__file__).parent))
from auto_approve import evaluate_command, load_rules, load_ssh_rules

LOG_FILE = Path.home() / ".claude" / "hooks" / "auto-approve.log"


def main():
    hook_input = json.load(sys.stdin)
    command = hook_input.get("tool_input", {}).get("command", "")
    if not command:
        return

    all_rules = []
    all_ssh_rules = []
    project_dir = os.environ.get("CLAUDE_PROJECT_DIR", "")
    if project_dir:
        project_yml = Path(project_dir) / ".claude" / "hooks" / "auto-approve.yml"
        all_rules.extend(load_rules(project_yml))
        all_ssh_rules.extend(load_ssh_rules(project_yml))
    global_yml = Path.home() / ".claude" / "hooks" / "auto-approve.yml"
    all_rules.extend(load_rules(global_yml))
    all_ssh_rules.extend(load_ssh_rules(global_yml))

    decision = evaluate_command(command, rules=all_rules, ssh_rules=all_ssh_rules)

    # Log
    try:
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        home = str(Path.home())
        proj = project_dir.replace(home, "~") if project_dir else "-"
        label = decision or "ask"
        cmd_short = command[:120]
        with open(LOG_FILE, "a") as f:
            f.write(f"{ts}  {label:5s}  {proj}  {cmd_short}\n")
    except OSError:
        pass

    if decision is None:
        return

    result = {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": decision,
        }
    }
    if decision == "deny":
        result["hookSpecificOutput"]["permissionDecisionReason"] = (
            "Denied by auto-approve hook"
        )
    json.dump(result, sys.stdout)


if __name__ == "__main__":
    main()
